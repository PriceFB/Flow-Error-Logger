<?xml version="1.0" encoding="UTF-8" ?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Flow Error Logger Admin</label>
    <description
  >Grants full access to the Flow Error Log object, its fields, tab, and the Flow Error Logger Apex classes. Assign to admins/developers who need to view and manage Flow error logs.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <objectPermissions>
        <object>Flow_Error_Log__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllFields>false</viewAllFields>
    </objectPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Flow_API_Name__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Error_Message__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Severity__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Record_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Flow_Interview_Guid__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Element_Name__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Running_User__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Flow_Error_Log__c.Context__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <tabSettings>
        <tab>Flow_Error_Log__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <classAccesses>
        <apexClass>FlowErrorLogger</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>FlowErrorLoggerRequest</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>FlowErrorNotifierNoOp</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>

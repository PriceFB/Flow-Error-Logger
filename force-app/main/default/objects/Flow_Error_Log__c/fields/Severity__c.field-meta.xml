<?xml version="1.0" encoding="UTF-8" ?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Severity__c</fullName>
    <label>Severity</label>
    <description
  >Classifies the impact of the logged error so teams can triage and prioritize failures.</description>
    <inlineHelpText
  >How serious the error is. Defaults to Error when not supplied.</inlineHelpText>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Info</fullName>
                <default>false</default>
                <label>Info</label>
            </value>
            <value>
                <fullName>Warning</fullName>
                <default>false</default>
                <label>Warning</label>
            </value>
            <value>
                <fullName>Error</fullName>
                <default>true</default>
                <label>Error</label>
            </value>
            <value>
                <fullName>Critical</fullName>
                <default>false</default>
                <label>Critical</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
